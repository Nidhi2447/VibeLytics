# AWS Configuration
AWS_REGION=us-east-1
# Note: In production, AWS credentials should be stored in AWS Secrets Manager
# Secret name: vibelytics/aws-credentials
# In development, you can use these environment variables:
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS Secrets Manager (for production)
AWS_SECRET_NAME=vibelytics/aws-credentials

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# DynamoDB Tables
DYNAMODB_SESSIONS_TABLE=vibelytics-sessions
DYNAMODB_SNAPSHOTS_TABLE=vibelytics-snapshots
DYNAMODB_ALERTS_TABLE=vibelytics-alerts
